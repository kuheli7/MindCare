# Backend
NODE_ENV=production
PORT=5000
MONGO_URI=
JWT_SECRET=

# Comma-separated list of allowed frontend origins for CORS
# Example: https://mindcare.netlify.app,https://mindcare.vercel.app
FRONTEND_ORIGIN=

# Optional email settings (required only if using contact/email features)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
CONTACT_RECEIVER_EMAIL=

# Frontend (for local .env files; set this in Netlify/Vercel UI)
VITE_API_BASE_URL=
